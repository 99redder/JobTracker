rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isApprovedUser() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/approvedUsers/$(request.auth.uid));
    }

    function canReadAppFiles() {
      return isAdmin() || isApprovedUser();
    }

    function isAllowedImageUpload() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }

    match /permits/{filePath=**} {
      allow read: if canReadAppFiles();
      allow create, update: if isAdmin() && isAllowedImageUpload();
      allow delete: if isAdmin();
    }

    match /licenses/{filePath=**} {
      allow read: if canReadAppFiles();
      allow create, update: if isAdmin() && isAllowedImageUpload();
      allow delete: if isAdmin();
    }
  }
}
