rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isApprovedUser() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/approvedUsers/$(request.auth.uid));
    }

    function canUseAppRecords() {
      return isAdmin() || isApprovedUser();
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /permits/{docId} {
      allow read: if canUseAppRecords();
      allow write: if isAdmin();
    }

    match /vehicles/{docId} {
      allow read: if canUseAppRecords();
      allow write: if isAdmin();
    }

    match /bills/{docId} {
      allow read: if canUseAppRecords();
      allow write: if isAdmin();
    }

    match /deposits/{docId} {
      allow read: if canUseAppRecords();
      allow write: if isAdmin();
    }

    match /inspections/{docId} {
      allow read: if canUseAppRecords();
      allow write: if isAdmin();
    }

    match /licenses/{docId} {
      allow read: if canUseAppRecords();
      allow write: if isAdmin();
    }

    match /activity/{docId} {
      allow read, write: if isAdmin();
    }

    match /approvedUsers/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow write: if isAdmin();
    }

    match /pendingUsers/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['uid', 'email', 'signupDate', 'status', 'authProvider'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    match /followups/{docId} {
      allow read, update, delete: if isAdmin();
      allow create: if isAdmin() || (
        isApprovedUser()
        && request.resource.data.keys().hasOnly(['category', 'itemId', 'itemTitle', 'flaggedBy', 'flaggedByEmail', 'flaggedAt'])
        && request.resource.data.category in ['permits', 'vehicles', 'bills', 'deposits', 'inspections', 'licenses']
        && request.resource.data.flaggedBy == request.auth.uid
        && request.resource.data.flaggedByEmail == request.auth.token.email
      );
    }
  }
}
