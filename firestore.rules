rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.uid in ['H9Iu95HshTNjQ86JZlH36hHsBw02'];
    }

    function isApprovedUser() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/approvedUsers/$(request.auth.uid));
    }

    function canUseAppRecords() {
      return isAdmin() || isApprovedUser();
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /permits/{docId} {
      allow read, write: if canUseAppRecords();
    }

    match /vehicles/{docId} {
      allow read, write: if canUseAppRecords();
    }

    match /bills/{docId} {
      allow read, write: if canUseAppRecords();
    }

    match /deposits/{docId} {
      allow read, write: if canUseAppRecords();
    }

    match /inspections/{docId} {
      allow read, write: if canUseAppRecords();
    }

    match /licenses/{docId} {
      allow read, write: if canUseAppRecords();
    }

    match /activity/{docId} {
      allow read, write: if canUseAppRecords();
    }

    match /approvedUsers/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow write: if isAdmin();
    }

    match /pendingUsers/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /followups/{docId} {
      allow read, update, delete: if isAdmin();
      allow create: if isAdmin() || (
        isSignedIn()
        && request.resource.data.flaggedBy == request.auth.uid
      );
    }
  }
}
